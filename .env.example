PORT=3000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
STORAGE_DIR=storage

OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_NOTES_MODEL=gpt-5
OPENAI_REASONING_EFFORT=low
OPENAI_TRANSCRIPTION_PROMPT=Transcribe this meeting recording accurately. Preserve speaker changes, decisions, deadlines, and named entities when audible.

NOTION_API_TOKEN=
NOTION_VERSION=2025-09-03
NOTION_DATA_SOURCE_ID=
NOTION_DATABASE_ID=
NOTION_TITLE_PROPERTY=Name
NOTION_SOURCE_PROPERTY=Source
NOTION_SOURCE_PROPERTY_TYPE=rich_text
NOTION_STATUS_PROPERTY=Status
NOTION_STATUS_PROPERTY_TYPE=rich_text
NOTION_PROCESSED_PROPERTY=Processed
NOTION_PROCESSED_PROPERTY_TYPE=rich_text
NOTION_DATE_PROPERTY=Created Date Time
NOTION_DATE_PROPERTY_TYPE=rich_text
NOTION_PAGE_ICON=📝

WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_GRAPH_VERSION=v22.0

MAX_UPLOAD_MB=150
